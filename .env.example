# LA Car Auctions — Environment Variable Reference
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any real secrets to version control.
# Real secrets must be stored in Vercel Environment Variables or GitHub Actions Secrets.

# ── Public (browser-safe) ──────────────────────────────────────────────────────
# Variables prefixed with NEXT_PUBLIC_ are inlined into the JS bundle at build time.
# Do NOT place sensitive values here.
NEXT_PUBLIC_APP_NAME=LA Car Auctions

# ── Server-only (never expose to browser) ─────────────────────────────────────
# Add server-side secrets here without the NEXT_PUBLIC_ prefix.
# Example (not currently used):
# OPG_API_TOKEN=
# DATABASE_URL=
